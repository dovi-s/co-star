OPENAI_API_KEY=your_openai_api_key_here
# Optional alternative names used by Replit AI Integrations code paths
AI_INTEGRATIONS_OPENAI_API_KEY=
# Optional: custom base URL (leave blank for default OpenAI API)
OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional: enables ElevenLabs text-to-speech routes
ELEVENLABS_API_KEY=

# Optional: override server port (default is 5000)
PORT=5000
